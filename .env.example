# Database
DB_URL=jdbc:postgresql://localhost:5432/antivirus
DB_USERNAME=postgres
DB_PASSWORD=postgres

# JWT
JWT_ACCESS_SECRET=ChangeThisAccessSecretWithAtLeast32Chars
JWT_REFRESH_SECRET=ChangeThisRefreshSecretWithAtLeast32Chars
JWT_ACCESS_EXPIRATION_SECONDS=900
JWT_REFRESH_EXPIRATION_SECONDS=604800

# TLS / HTTPS
TLS_ENABLED=true
TLS_KEYSTORE_PATH=certs/server-keystore.p12
TLS_KEYSTORE_PASSWORD=changeit
TLS_KEY_ALIAS=server

# Seed users
APP_SEED_ADMIN_USERNAME=admin
APP_SEED_ADMIN_PASSWORD=admin12345
APP_SEED_USER_USERNAME=user
APP_SEED_USER_PASSWORD=user12345
